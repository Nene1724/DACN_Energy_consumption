# Copy this file to `.env` and fill in values.
# IMPORTANT: Do not commit real tokens.

# Balena API (required if using Balena features)
BALENA_API_TOKEN=
# BALENA_SESSION_TOKEN=

# Public URL that devices can reach to download models (recommended for cross-network)
# Example: http://<PUBLIC_IP>:5000
CONTROLLER_PUBLIC_URL=
